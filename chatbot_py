def _get_fallback(message: str) -> str:
    msg = message.lower()
    if any(w in msg for w in ["reward","penalty","score","-50","bonus"]):
        return _FALLBACK_RESPONSES["reward"]
    if any(w in msg for w in ["q-learn","qlearn","q learn","epsilon","exploration","exploit","replay"]):
        return _FALLBACK_RESPONSES["qlearning"]
    if any(w in msg for w in ["vital","spo2","oxygen","heart rate","blood pressure","hr","bp"]):
        return _FALLBACK_RESPONSES["vitals"]
    if any(w in msg for w in ["triage","priority","discharge","urgent","level","protocol"]):
        return _FALLBACK_RESPONSES["triage"]
    return _FALLBACK_RESPONSES["default"]


def call_claude_api(messages: list, api_key: str) -> str:
    """Call Claude API directly via urllib (no anthropic package needed)."""
    payload = json.dumps({
        "model": "claude-sonnet-4-20250514",
        "max_tokens": 600,
        "system": SYSTEM_PROMPT,
        "messages": messages,
    }).encode("utf-8")

    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=payload,
        headers={
            "Content-Type":      "application/json",
            "x-api-key":         api_key,
            "anthropic-version": "2023-06-01",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=20) as resp:
            data = json.loads(resp.read().decode("utf-8"))
            return data["content"][0]["text"]
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        if e.code == 401:
            return "❌ Invalid API key. Check your key and try again."
        if e.code == 429:
            return "⚠️ Rate limit hit. Please wait a moment and retry."
        return f"❌ API error ({e.code}): {body[:200]}"
    except Exception as ex:
        return f"❌ Connection error: {str(ex)[:200]}"


def chat(
    user_message: str,
    history: list,
    api_key: str = "",
    patient_context: dict = None,
) -> tuple[list, str]:
    """
    Main chat function.
    Args:
        user_message:    The user's message.
        history:         List of [user, assistant] pairs.
        api_key:         Optional Anthropic API key.
        patient_context: Optional current patient state to inject as context.
    Returns:
        (updated_history, "")
    """
    if not user_message.strip():
        return history, ""

    # Build context prefix if patient is active
    context_prefix = ""
    if patient_context:
        context_prefix = (
            f"[Current patient context: "
            f"Symptoms: {', '.join(patient_context.get('symptoms', []))}. "
            f"HR: {patient_context.get('heart_rate', 'N/A')} bpm. "
            f"SpO₂: {patient_context.get('oxygen_level', 'N/A')}%. "
            f"BP: {patient_context.get('blood_pressure', 'N/A')}. "
            f"Age: {patient_context.get('age', 'N/A')} years.]\n\n"
        )

    full_message = context_prefix + user_message

    if api_key and api_key.strip().startswith("sk-ant-"):
        # Build message history for API
        api_messages = []
        for user_turn, asst_turn in history[-6:]:  # last 6 turns context
            api_messages.append({"role": "user",      "content": user_turn})
            api_messages.append({"role": "assistant", "content": asst_turn})
        api_messages.append({"role": "user", "content": full_message})

        response = call_claude_api(api_messages, api_key.strip())
    else:
        response = _get_fallback(user_message)
        if not api_key:
            response += "\n\n---\n*🔑 Add your Anthropic API key above for full AI responses.*"

    history = history + [[user_message, response]]
    return history, ""


def build_patient_summary_prompt(state: dict, action: str, reward: float) -> str:
    """Generate a pre-filled prompt explaining the last triage decision."""
    syms = ", ".join(state.get("symptoms", []))
    hr   = state.get("heart_rate",    "?")
    o2   = state.get("oxygen_level",  "?")
    bp   = state.get("blood_pressure","?")
    age  = state.get("age",           "?")
    sign = "+" if reward >= 0 else ""
    return (
        f"Explain this triage decision: Patient has {syms}. "
        f"Vitals: HR={hr}, SpO₂={o2}%, BP={bp}, age={age}. "
        f"Action taken: '{action}' (reward: {sign}{reward}). "
        f"Was this correct and why?"
    )
